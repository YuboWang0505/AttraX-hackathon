# Gemini API key (optional in dev/hackathon).
# When absent, the intent pipeline skips layer 2 and returns
# {intent_code: "S_TEASE_LIGHT", intensity: 1} for unmatched text.
GEMINI_API_KEY=

# OpenRouter key for LLM-based intent classification (layer 2 of pipeline).
OPENROUTER_API_KEY=
# Optional override; defaults to x-ai/grok-4-fast.
# OPENROUTER_MODEL=

# SiliconFlow key for voice-call STT (api.siliconflow.cn, reachable from
# mainland China, OpenAI-compatible). Without this, /api/stt returns empty
# text and voice calls will have no intensity-driving pipeline.
SILICONFLOW_API_KEY=
# Optional override; defaults to FunAudioLLM/SenseVoiceSmall.
# SILICONFLOW_MODEL=

# Server port (default: 3000)
PORT=3000
