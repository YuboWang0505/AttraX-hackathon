# OpenRouter key for LLM-based intent classification (layer 2 of pipeline).
# Without this, the LLM layer returns null (no intensity update).
OPENROUTER_API_KEY=
# Optional override; defaults to x-ai/grok-4-fast.
# OPENROUTER_MODEL=

# SiliconFlow key for voice-call STT (api.siliconflow.cn, reachable from
# mainland China, OpenAI-compatible). Without this, /api/stt returns empty
# text — voice calls themselves still work, but speech is not transcribed
# into chat messages, so the intensity pipeline won't fire from voice.
SILICONFLOW_API_KEY=
# Optional override; defaults to FunAudioLLM/SenseVoiceSmall.
# SILICONFLOW_MODEL=

# Server port (Render auto-injects this; locally defaults to 3000).
PORT=3000

# Comma-separated list of allowed CORS origins. Set this in prod to your
# Cloudflare Pages URL(s). Empty = allow all (dev only).
# Example: ALLOWED_ORIGINS=https://attrax.pages.dev,https://main.attrax.pages.dev
ALLOWED_ORIGINS=
